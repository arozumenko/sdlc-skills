# mobile-qa bundle — environment variable template.
#
# Copy to `.env` in your project root and fill in real values.
# The file is loaded automatically by Claude Code via shell env.
#
# Export before registering the MCP server:
#   set -a; source .env; set +a     (bash/zsh)
#   Get-Content .env | Where-Object { $_ -notmatch '^#|^\s*$' } | foreach { $k,$v = $_ -split '=',2; [System.Environment]::SetEnvironmentVariable($k,$v.Trim()) }   (PowerShell)
#
# Then register the Mobitru MCP server once per project:
#   claude mcp add mobitru -e MOBITRU_API_TOKEN=$MOBITRU_API_TOKEN -- npx -y mobitru-mcp-server@latest
#
# Already-exported shell env vars always win over .env values.
# Never commit .env. The project .gitignore already covers it.

# ─── Mobitru Device Farm ──────────────────────────────────────────
# Issue at: Mobitru dashboard → Account → API Access → Generate Token
MOBITRU_API_TOKEN=

# Optional: override the default Mobitru API endpoint (leave blank for cloud SaaS)
# MOBITRU_BASE_URL=https://app.mobitru.com
