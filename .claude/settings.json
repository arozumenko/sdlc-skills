{
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}/.claude/hooks/sdlc-skills/run-hook.cmd\" session-start",
            "async": false
          }
        ],
        "_bundle": "sdlc-core"
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}/.claude/hooks/sdlc-skills/run-hook.cmd\" agent-start",
            "async": false
          }
        ],
        "_bundle": "sdlc-core"
      }
    ]
  }
}
